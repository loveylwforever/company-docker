# =============================================================================
# company-docker 环境变量示例
# =============================================================================
# 用法（在 company-docker 目录下）：
#   cp .env.example .env
#   docker compose up -d --build
#
# 适用编排：
#   docker-compose.yml          — 本机开发（自研镜像标签 :local）
#   docker-compose-amd64.yml    — 阿里云 amd64 发布（自研镜像标签 :amd64）
#   docker-compose-local.yml    — 仅中间件（Postgres / Redis / Artemis）
#
# 说明：改密码或 API 地址后执行 docker compose up -d 使依赖服务重新加载环境变量。

# -----------------------------------------------------------------------------
# PostgreSQL（postgres 服务）
# -----------------------------------------------------------------------------
# 数据库超级用户密码；auth / auth-channel / manage / admin-dashboard 均复用此密码连接 company_auth
POSTGRES_PASSWORD=postgres
# 宿主机映射端口（容器内固定 5432）
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis（redis 服务）
# -----------------------------------------------------------------------------
# requirepass；auth 使用 DB0，manage 使用 DB1（库号在 compose 内写死，不在此配置）
REDIS_PASSWORD=123456
# 宿主机映射端口（容器内固定 6379）
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# ActiveMQ Artemis（artemis 服务）
# -----------------------------------------------------------------------------
# 控制台与 JMS 登录用户名（映射为容器内 ARTEMIS_USER）
MQ_USERNAME=admin
# 控制台与 JMS 登录密码（映射为容器内 ARTEMIS_PASSWORD）
MQ_PASSWORD=Artemis@2026
# Web 管理控制台宿主机端口（容器内 8161，默认账号见 MQ_USERNAME / MQ_PASSWORD）
ARTEMIS_CONSOLE_PORT=8161
# Core 协议（JMS）宿主机端口（容器内 61616；auth / auth-channel 通过 tcp://artemis:61616 连接）
ARTEMIS_CORE_PORT=61616
# AMQP 协议宿主机端口（容器内 5672；当前 Java 服务未使用，预留给其他客户端）
ARTEMIS_AMQP_PORT=5672

# -----------------------------------------------------------------------------
# company-auth（auth 服务）
# -----------------------------------------------------------------------------
# 宿主机映射 HTTP 端口（容器内 SERVER_PORT=8080）
AUTH_PORT=8080
# Spring Boot profile；prod 时日志写入 ./auth/logs
AUTH_SPRING_PROFILES_ACTIVE=prod

# -----------------------------------------------------------------------------
# company-auth-channel（auth-channel 服务）
# -----------------------------------------------------------------------------
# 宿主机映射 HTTP 端口（容器内 SERVER_PORT=8090）
AUTH_CHANNEL_PORT=8090
# Spring Boot profile；prod 时日志写入 ./auth-channel/logs
CHANNEL_SPRING_PROFILES_ACTIVE=prod

# -----------------------------------------------------------------------------
# 服务间 API 地址（manage、admin-dashboard）
# -----------------------------------------------------------------------------
# company-auth 根地址（无尾斜杠）
# - 全栈 compose 默认：http://auth:8080
# - manage：产品自测等转发 auth
# - admin-dashboard：Nitro BFF 将 /api/auth/* 代理到此地址
AUTH_API_BASE=http://auth:8080

# company-auth-channel 根地址（无尾斜杠）
# - 全栈 compose 默认：http://auth-channel:8090
# - admin-dashboard：Nitro BFF 将 /api/channel-release/* 代理到此地址（渠道插件发布等）
CHANNEL_RELEASE_API_BASE=http://auth-channel:8090

# -----------------------------------------------------------------------------
# company-manage（manage 服务）
# -----------------------------------------------------------------------------
# 宿主机映射 HTTP 端口（容器内 8088；admin-dashboard 通过 MANAGE_API_BASE 访问）
COMPANY_MANAGE_PORT=8088
# Spring Boot profile；prod 时日志写入 ./manage/logs
MANAGE_SPRING_PROFILES_ACTIVE=prod

# -----------------------------------------------------------------------------
# admin-dashboard（admin-dashboard 服务）
# -----------------------------------------------------------------------------
# 宿主机映射 HTTP 端口（容器内 PORT=3000；浏览器访问 http://127.0.0.1:该端口）
ADMIN_DASHBOARD_PORT=3000

# -----------------------------------------------------------------------------
# 构建相关（docker-compose-amd64.yml / build-push-amd64.sh）
# -----------------------------------------------------------------------------
# 自研四服务镜像标签：本地 compose 固定 :local；amd64 编排与离线包默认 :amd64
#IMAGE_TAG=amd64
# admin-dashboard 镜像构建时 Node.js 堆上限（MB）；内存不足导致构建 OOM 时可调至 3072
#NODE_HEAP_MB=2048

# build-push-amd64.sh 可选（一般无需写入 .env）：
# OUTPUT_DIR=./dist
# PLATFORM=linux/amd64
